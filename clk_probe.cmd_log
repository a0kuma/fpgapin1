par -w -intstyle ise -ol high -mt off clk_probe_map.ncd clk_probe.ncd clk_probe.pcf 
trce -intstyle ise -v 3 -s 2 -n 3 -fastpaths -xml clk_probe.twx clk_probe.ncd -o clk_probe.twr clk_probe.pcf -ucf blink.ucf 
bitgen -intstyle ise -f clk_probe.ut clk_probe.ncd 
